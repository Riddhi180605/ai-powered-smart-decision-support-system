# ==========================================
# Data Analysis Tool - Environment Variables
# ==========================================
# Copy this file to .env and fill in your values

# ========== SERVER CONFIGURATION ==========
# Application host (0.0.0.0 for all interfaces, localhost for local only)
APP_HOST=0.0.0.0

# Application port (Render uses random port, local development uses 8001)
APP_PORT=8080

# Allowed origins for CORS (comma-separated)
# For production: your-domain.com,www.your-domain.com
# For development: http://localhost:3000,http://localhost:8000,http://localhost:8001
ALLOWED_ORIGINS=*

# ========== AI/LLM CONFIGURATION ==========
# OpenAI API Key (for AI insights and RAG)
OPENAI_API_KEY=sk-your-key-here

# Groq API Key (alternative to OpenAI, optional)
GROQ_API_KEY=gsk-your-groq-key-here

# ========== DEPLOYMENT SPECIFIC ==========
# For local development, you can leave most of these as defaults
# Render will auto-configure these on their platform

# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode (set to false in production)
DEBUG=true
